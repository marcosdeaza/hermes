# ─── B.AI API (kimi-k2.5 / glm-5.2) ─────────────────────────────────────────
BAI_API_KEY=your_bai_api_key_here
BAI_BASE_URL=https://api.b.ai/v1
BAI_MODEL=kimi-k2.5

# ─── GROQ (Whisper voice transcription) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── PATHS (optional, defaults are relative to project root) ─────────────────
WHATSAPP_SESSION_PATH=./.wwebjs_auth
PROJECTS_PATH=./projects
LOG_PATH=./logs
MAX_OUTPUT_LENGTH=10000

# ─── OWNER (optional — auto-registered on first WhatsApp contact) ─────────────
OWNER_NUMBER=

# ─── MISC ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
