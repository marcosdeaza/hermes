# ─── AI Provider (OpenAI-compatible) ─────────────────────────────────────────
# Pick one provider and fill in its key + base URL.
# The API just needs to be OpenAI-compatible (/chat/completions).

# Option A — OpenRouter (access to Claude, GPT-4o, Gemini, Llama, etc.)
AI_API_KEY=your_openrouter_key_here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=anthropic/claude-sonnet-4-5

# Option B — z.ai
# AI_API_KEY=your_zai_key_here
# AI_BASE_URL=https://api.z.ai/v1
# AI_MODEL=z1-preview

# Option C — any other OpenAI-compatible provider
# AI_API_KEY=your_key_here
# AI_BASE_URL=https://your-provider.com/v1
# AI_MODEL=your-model-id

# ─── GROQ (Whisper voice transcription) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── PATHS (optional, defaults are relative to project root) ─────────────────
WHATSAPP_SESSION_PATH=./.wwebjs_auth
PROJECTS_PATH=./projects
LOG_PATH=./logs
MAX_OUTPUT_LENGTH=10000

# ─── OWNER (optional — auto-registered on first WhatsApp contact) ─────────────
OWNER_NUMBER=

# ─── MISC ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
